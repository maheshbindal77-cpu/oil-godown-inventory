# -------------------------------------------------------------------
# TEMPLATE — do not put real values here. This file is safe to share.
#
# When deploying on Streamlit Community Cloud, you paste the real
# values into the app's "Secrets" box in the Streamlit dashboard
# (NOT into any file that goes to GitHub).
#
# For local testing you may copy this file to "secrets.toml" in the
# same folder and fill in real values — secrets.toml is gitignored.
# -------------------------------------------------------------------

# The connection string from your Neon database (starts with postgresql://)
db_url = "postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# The password you and your father will type to open the app
app_password = "choose-a-strong-password"
